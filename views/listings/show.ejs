<%= layout("/layouts/boilerplate.ejs")%>
<div class="row mt-4 show-page">
    <div class="col-8 offset-2">
        <h3>Listing Details</h3>
    </div>
    <div class="card col-6  show-card">
            <img src="<%=listing.image.url%>" class="card-img-top show-page" alt="listing_image">
            <div class="card-body">
              <p class="card-text">
                <b><%=listing.title%></b>
                <br><% if (listing.price != null) { %>
                    <br>&#8377;<%= listing.price.toLocaleString("en-IN") %> <br>
                <% } else { %>
                    <br>Price not available<br>
                <% } %>
                <br>
                <%=listing.location%> <br>
                <%=listing.country%> <br>
                
            </p>
            </div>
        </div>
            
            <br>
           
        
    </div>
    <br>
    
</div>
<div class="row">

    <div class="btns">
        <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark Edit-btn">Edit This Listing</a>
    
    <br>
    
        <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
            <button class="btn btn-dark Delete-btn">Delete This Listing</button>
        </form>
    </div>
</div>
