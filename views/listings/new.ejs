<%= layout("/layouts/boilerplate.ejs")%>

    
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <br>
            <br>
            <h3>Create a new listing</h3>
            <form method="post" action="/listings">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input class="form-control" name="listing[title]" type="text" placeholder="enter title">
                </div>
                <div class="mb-3">
                    <label for="description">Description</label>
                    <textarea name="listing[description]" class="form-control"></textarea>
                </div>
                <div class="mb-3">
                    <label for="image">Image</label>
                    <input class="form-control" name="listing[image]" type="text" placeholder="enter image URL/Link">
                </div>
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price">Price</label>
                        <input class="form-control" name="listing[price]" type="number" placeholder="enter Price">
                    </div>
                    <div class="mb-3 col-md-8">
                        <label for="country">Country</label>
                        <input class="form-control" name="listing[country]" type="text" placeholder="enter country">
                    </div>
                </div>
                
                <div class="mb-3">
                    <label for="location">Location</label>
                    <input class="form-control" name="listing[location]" type="text" placeholder="enter location">
                </div>
                
                <br><br> 
                <button  class="btn btn-dark mt-3 add-btn">Add</button>
            </form>
        </div>
    </div>
    
